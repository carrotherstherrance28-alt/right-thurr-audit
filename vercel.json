{
  "headers": [
    {
      "source": "/use-cases/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/diagnostic",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/diagnostic/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/diagnostic/roofing-contractor",
      "destination": "/diagnostic/roofing-contractor.html"
    },
    {
      "source": "/diagnostic/med-spa",
      "destination": "/diagnostic/med-spa.html"
    },
    {
      "source": "/diagnostic/mobile-detailing",
      "destination": "/diagnostic/mobile-detailing.html"
    },
    {
      "source": "/owner/callback",
      "destination": "/"
    },
    {
      "source": "/audit",
      "destination": "/"
    },
    {
      "source": "/audit/thanks",
      "destination": "/"
    },
    {
      "source": "/diagnostic",
      "destination": "/diagnostic/index.html"
    },
    {
      "source": "/use-cases",
      "destination": "/"
    },
    {
      "source": "/use-cases/:path*",
      "destination": "/"
    },
    {
      "source": "/diagnostic/:path*",
      "destination": "/"
    }
  ]
}
